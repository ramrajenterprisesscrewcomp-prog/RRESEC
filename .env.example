# Copy to .env for local reference only — never commit the real .env file.
# On Vercel/production, set these as actual environment variables instead
# (Project → Settings → Environment Variables), not via a checked-in .env file.

# Optional. Only needed for Google Sheet sync. Paste the full contents of the
# downloaded service-account JSON key as a single line. If unset, the app
# falls back to reading data/google-key.json from disk (local dev only).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Optional. Fallback SMTP login used only when Settings has none saved in the
# database — keeps email working on hosts where the DB does not persist
# (e.g. Vercel's ephemeral /tmp). A value entered in Settings still wins.
# App password is the 16-character one from Google Account > Security >
# 2-Step Verification > App passwords (no spaces).
GMAIL_SENDER=you@example.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Optional. Fallback Google Sheet ID used only when Settings has none saved —
# same reasoning as the SMTP vars above. The sheet must be shared with the
# service account email (see GOOGLE_SERVICE_ACCOUNT_JSON) as Editor.
GSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Only used when the database is completely empty (e.g. a fresh
# Vercel cold start) — auto-creates this account as admin so it doesn't need
# to be re-registered by hand each reset. Ignored once any user exists.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-real-password
