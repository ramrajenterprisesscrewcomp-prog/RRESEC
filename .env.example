# Copy to .env for local reference only — never commit the real .env file.
# On Railway/production, set these as actual environment variables instead
# (Project → Variables), not via a checked-in .env file.

# Optional. Only needed for Google Sheet sync. Paste the full contents of the
# downloaded service-account JSON key as a single line. If unset, the app
# falls back to reading data/google-key.json from disk (local dev only).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
