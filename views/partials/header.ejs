<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title><%= title %> · Appointment Secretary</title>
<link rel="stylesheet" href="/style.css">
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/icon-192.png">
<link rel="apple-touch-icon" href="/icon-192.png">
<meta name="theme-color" content="#1e1b4b">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Secretary">
</head>
<body class="<%= user ? 'has-tabbar' : '' %>">
<% if (user) { %>
<nav class="topnav">
  <span class="brand">📅 Secretary</span>
  <a href="/">Appointments</a>
  <a href="/appointments/new">+ New</a>
  <a href="/logs">Log</a>
  <% if (user.role === 'admin') { %>
    <a href="/settings">Settings</a>
    <a href="/users">Users</a>
  <% } %>
  <span class="spacer"></span>
  <button class="link notif-toggle" type="button" title="Alerts 30 minutes before your appointments">🔔</button>
  <a href="/profile" class="who"><%= user.name %><% if (user.role === 'admin') { %> (admin)<% } %></a>
  <form method="post" action="/logout" class="inline"><button class="link" type="submit">Log out</button></form>
</nav>
<% } %>
<main>
<% if (msg) { %><div class="flash <%= msg.type %>"><%= msg.text %></div><% } %>
