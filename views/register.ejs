<%- include('partials/header') %>
<div class="card auth">
  <h1>Create account</h1>
  <% if (firstRun) { %>
    <p class="hint">This is the <strong>first account</strong>, so it will be the <strong>admin</strong> (can open Settings and manage users).</p>
  <% } %>
  <form method="post" action="/register">
    <label>Your name
      <input type="text" name="name" required autofocus>
    </label>
    <label>Email
      <input type="email" name="email" required>
    </label>
    <label>Password (at least 6 characters)
      <input type="password" name="password" minlength="6" required>
    </label>
    <label>Your time zone
      <select name="timezone" id="tzselect">
        <% for (const z of timezones) { %>
          <option value="<%= z.value %>" <%= z.value === defaultTz ? 'selected' : '' %>><%= z.label %></option>
        <% } %>
      </select>
    </label>
    <p class="hint">Detected automatically — change it if wrong. All times you see will be in this zone.</p>
    <button type="submit" class="primary">Create account</button>
  </form>
  <script>
    (function () {
      var detected = Intl.DateTimeFormat().resolvedOptions().timeZone;
      var sel = document.getElementById('tzselect');
      if (detected && sel.querySelector('option[value="' + detected + '"]')) sel.value = detected;
    })();
  </script>
  <p class="hint">Already have an account? <a href="/login">Log in</a></p>
</div>
<%- include('partials/footer') %>
